# Ignora TUDO por padrao
/*

# Mantem o proprio .gitignore
!.gitignore

# Permite descer ate saida/ (mas nao traz README.md, scripts/, docs/, pdfs_origem/, temp/)
!saida/

# Dentro de saida/: ignora tudo, depois libera SO as figurinhas, os .json e produtos/
saida/*
!saida/figurinhas/
!saida/*.json
!saida/produtos/
!saida/nordestinos/

# subpasta brasil_atualizado: apenas o .json (nao os recortes brutos)
!saida/brasil_atualizado/
saida/brasil_atualizado/*
!saida/brasil_atualizado/*.json
